{
  "manifest_version": 3,
  "name": "ScrollMirror",
  "version": "2.0",
  "description": "Gentle scroll-time awareness with streaks, charts & Pomodoro breaks",

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*",
        "https://*.tiktok.com/*",
        "https://*.youtube.com/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.tiktok.com/*",
    "https://*.youtube.com/*"
  ],

  "action": {
    "default_title": "ScrollMirror",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
